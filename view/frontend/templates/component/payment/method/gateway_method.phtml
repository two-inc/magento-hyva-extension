                                        <?= $escaper->escapeHtmlAttr(
                                            __("Enter details manually"),
                                        ) ?>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Toggle link based on mode -->
                    <div class="w-full text-right" x-show="manualMode">
